# Application
NODE_ENV=production
PORT=3010
SERVICE_NAME=ipmyp-geoip-api

# Redis
REDIS_URL=redis://redis:6379

# Rate limiting
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=45
MAX_BATCH_SIZE=50

# Reverse proxy / real client IP
# Keep false if the container is directly exposed to the internet.
# Set true only when the app is behind a trusted reverse proxy such as Nginx, Cloudflare or ArvanCloud.
TRUST_PROXY=false

# Optional access control
# Comma-separated hostnames, examples: ipmyp.ir,www.ipmyp.ir,ipmyp.com,www.ipmyp.com
ORIGIN_WHITELIST=

# Comma-separated exact client IP addresses allowed to bypass origin restrictions
IP_WHITELIST=

# CORS
# Empty value disables CORS headers. Use comma-separated origins for browser access.
CORS_ALLOWED_ORIGINS=https://ipmyp.ir,https://www.ipmyp.ir,https://ipmyp.com,https://www.ipmyp.com

# JSONP is disabled by default for security. Enable only when you explicitly need legacy script-tag integrations.
JSONP_ENABLED=false

# MaxMind credentials are required by the geolite2 package at install/build time.
# Do not commit real values to GitHub.
MAXMIND_ACCOUNT_ID=your_maxmind_account_id
MAXMIND_LICENSE_KEY=your_maxmind_license_key
